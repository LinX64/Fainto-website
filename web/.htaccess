# The Fainto web viewer ships two kinds of page from this directory:
#   - index.html / dashboard.html: single self-contained files, all CSS/JS
#     inline, no network calls — the "nothing leaves your device" offline
#     guarantee is enforced at the header level with connect-src 'none'.
# The retired sample viewer demo.html is 301'd to dashboard.html below (the lftp
# deploy never deletes remote files, so the redirect is what takes it down).
#   - app.html: the signed-in web companion, which talks to Firebase Auth /
#     Firestore and therefore needs a scoped-open connect-src instead.
# Each file gets its own CSP block below — do not merge them back into one
# directory-wide header or app.html's Firebase calls (or the offline lock on
# index/dashboard) will break again.

Options -Indexes

RedirectMatch 301 ^/web/demo\.html$ /web/dashboard.html

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=(), usb=(), payment=(), interest-cohort=(), browsing-topics=()"
  Header always set X-Frame-Options "SAMEORIGIN"

  <FilesMatch "^(dashboard|app)\.html$">
    Header always set X-Robots-Tag "noindex, nofollow"
  </FilesMatch>

  <FilesMatch "^(index|dashboard)\.html$">
    Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'none'; form-action 'self'; upgrade-insecure-requests"
  </FilesMatch>

  <Files "app.html">
    Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://apis.google.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://*.googleapis.com https://securetoken.googleapis.com https://identitytoolkit.googleapis.com https://firestore.googleapis.com; frame-src https://vaultai-26d8f.firebaseapp.com https://accounts.google.com https://apis.google.com; form-action 'self'; upgrade-insecure-requests"

    # The ROOT .htaccess sets Cross-Origin-Opener-Policy "same-origin", and mod_headers
    # inherits it into this directory. That severs the opener link that Firebase's
    # signInWithPopup needs to hand the credential back, so Google sign-in hangs on a
    # popup that never resolves. Only this page opens an auth popup, so relax it here
    # (and only here) — index/dashboard keep the strict root policy.
    Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
  </Files>
</IfModule>
