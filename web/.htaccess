# The Fainto web viewer ships two kinds of page from this directory:
#   - index.html / demo.html / dashboard.html: single self-contained files, all
#     CSS/JS inline, no network calls — the "nothing leaves your device" offline
#     guarantee is enforced at the header level with connect-src 'none'.
#   - app.html: the signed-in web companion, which talks to Firebase Auth /
#     Firestore and therefore needs a scoped-open connect-src instead.
# Each file gets its own CSP block below — do not merge them back into one
# directory-wide header or app.html's Firebase calls (or the offline lock on
# index/demo) will break again.

<IfModule mod_headers.c>
  <FilesMatch "^(index|demo|dashboard)\.html$">
    Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'none'; form-action 'self'; upgrade-insecure-requests"
  </FilesMatch>

  <Files "app.html">
    Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://*.googleapis.com https://securetoken.googleapis.com https://identitytoolkit.googleapis.com https://firestore.googleapis.com; frame-src https://vaultai-26d8f.firebaseapp.com https://accounts.google.com; form-action 'self'; upgrade-insecure-requests"
  </Files>
</IfModule>
