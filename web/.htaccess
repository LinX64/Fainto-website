# The Fainto web viewer is a single self-contained file: all CSS and JS are inline
# (by design, so the exact same file the Android app exports opens offline anywhere).
# The site-wide CSP in the parent .htaccess is first-party-only (no 'unsafe-inline'),
# which blocks every inline <style> and <script> here and leaves the page unstyled.
# Override the CSP for THIS directory only: allow inline style/script, but keep
# connect-src 'none' so the viewer still cannot make any network request — the
# "nothing leaves your device" guarantee is enforced at the header level too.

<IfModule mod_headers.c>
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'none'; form-action 'self'; upgrade-insecure-requests"
</IfModule>
